{
  "name": "tag-explorer",
  "version": "0.1.0",
  "description": "A tag-based file explorer with tag-folders, drag-and-drop, and untagged notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "privacy-check": "node scripts/privacy-check.mjs",
    "lint:obsidian": "eslint \"src/**/*.ts\"",
    "bump-version": "node scripts/bump-version.mjs",
    "release:check": "node scripts/bump-version.mjs --check && npm run typecheck && npm test && npm run build && npm run privacy-check && npm audit --omit=dev && npm run lint:obsidian"
  },
  "keywords": [
    "obsidian",
    "tag-explorer",
    "tags"
  ],
  "author": "metrdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metrdev/tag-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/metrdev/tag-explorer/issues"
  },
  "homepage": "https://github.com/metrdev/tag-explorer#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.14.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/parser": "^8.62.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "tslib": "^2.6.3",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.0"
  }
}
